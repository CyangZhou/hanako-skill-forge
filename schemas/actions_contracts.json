{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "hanako.skill.forge.actions.v2",
  "title": "hanako-skill-forge 脚本动作契约",
  "type": "object",
  "required": ["actions"],
  "properties": {
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "module_index": {
          "$ref": "#/$defs/actionNoInput"
        },
        "audit_refs": {
          "$ref": "#/$defs/actionNoInput"
        },
        "audit_terms": {
          "type": "object",
          "required": ["description", "input"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string"
            },
            "input": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "terms": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "要扫描的术语列表"
                },
                "exclude": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "跳过扫描的相对路径列表"
                }
              }
            }
          }
        },
        "audit_skill": {
          "$ref": "#/$defs/actionNoInput"
        }
      }
    }
  },
  "$defs": {
    "actionNoInput": {
      "type": "object",
      "required": ["description", "input"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "description": "无需输入参数"
        }
      }
    }
  }
}
